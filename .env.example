# Supabase
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Groq (LLM for questions, evaluation, resume analysis)
GROQ_API_KEY=your-groq-api-key

# Google Cloud TTS
GCP_TTS_API_KEY=your-gcp-tts-key

# Razorpay (payments)
VITE_RAZORPAY_KEY_ID=your-razorpay-key-id
RAZORPAY_KEY_ID=your-razorpay-key-id
RAZORPAY_KEY_SECRET=your-razorpay-key-secret

# Resend (payment confirmation emails)
RESEND_API_KEY=your-resend-api-key
# FROM_EMAIL=HireReady <onboarding@resend.dev>

# Upstash Redis (persistent rate limiting, optional — falls back to in-memory)
# UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
# UPSTASH_REDIS_REST_TOKEN=your-upstash-token

# Cron job secret (protects /api/send-renewal-reminders)
# CRON_SECRET=your-random-secret

# CORS (comma-separated production domains, optional)
# ALLOWED_ORIGINS=https://yourdomain.com,https://levelup-taupe.vercel.app
