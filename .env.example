# Supabase
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Groq (LLM for questions, evaluation, resume analysis)
GROQ_API_KEY=your-groq-api-key

# Google Gemini (LLM fallback when Groq is unavailable)
GEMINI_API_KEY=your-gemini-api-key

# Azure TTS (primary text-to-speech — Indian English voices)
AZURE_TTS_KEY=your-azure-cognitive-services-key
AZURE_TTS_REGION=centralindia

# Cartesia TTS (fallback text-to-speech)
CARTESIA_API_KEY=your-cartesia-api-key

# Deepgram (primary speech-to-text — Nova-3 with multi-language)
DEEPGRAM_API_KEY=your-deepgram-api-key

# Sarvam AI (fallback speech-to-text — Hinglish code-switching)
SARVAM_API_KEY=your-sarvam-api-key

# Razorpay (payments)
VITE_RAZORPAY_KEY_ID=your-razorpay-key-id
RAZORPAY_KEY_ID=your-razorpay-key-id
RAZORPAY_KEY_SECRET=your-razorpay-key-secret
RAZORPAY_WEBHOOK_SECRET=your-razorpay-webhook-secret

# App URL (used in email links, required for production)
APP_URL=https://levelup-taupe.vercel.app

# Resend (payment confirmation emails)
RESEND_API_KEY=your-resend-api-key
# FROM_EMAIL=HireReady <onboarding@resend.dev>

# Upstash Redis (persistent rate limiting, optional — falls back to in-memory)
# UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
# UPSTASH_REDIS_REST_TOKEN=your-upstash-token

# Cron job secret (protects /api/send-renewal-reminders)
# CRON_SECRET=your-random-secret

# CORS (comma-separated production domains, optional)
# ALLOWED_ORIGINS=https://yourdomain.com,https://levelup-taupe.vercel.app
