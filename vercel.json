{
  "buildCommand": "vite build",
  "outputDirectory": "dist",
  "framework": "vite",
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(self), geolocation=()" },
        { "key": "Strict-Transport-Security", "value": "max-age=63072000; includeSubDomains; preload" },
        { "key": "Content-Security-Policy", "value": "default-src 'self'; script-src 'self' https://checkout.razorpay.com https://*.razorpay.com https://va.vercel-scripts.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com https://*.razorpay.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: blob: https://images.unsplash.com https://*.supabase.co https://*.razorpay.com; connect-src 'self' https://*.supabase.co wss://*.supabase.co https://api.groq.com https://generativelanguage.googleapis.com https://*.razorpay.com https://lumberjack.razorpay.com https://*.upstash.io https://vitals.vercel-insights.com https://va.vercel-scripts.com; frame-src https://api.razorpay.com https://checkout.razorpay.com; media-src 'self' blob:; worker-src 'self' blob:;" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/api/tts", "destination": "/api/tts" },
    { "source": "/api/voices", "destination": "/api/voices" },
    { "source": "/api/generate-questions", "destination": "/api/generate-questions" },
    { "source": "/api/evaluate", "destination": "/api/evaluate" },
    { "source": "/api/follow-up", "destination": "/api/follow-up" },
    { "source": "/api/analyze-resume", "destination": "/api/analyze-resume" },
    { "source": "/api/create-order", "destination": "/api/create-order" },
    { "source": "/api/verify-payment", "destination": "/api/verify-payment" },
    { "source": "/api/cancel-subscription", "destination": "/api/cancel-subscription" },
    { "source": "/api/reactivate-subscription", "destination": "/api/reactivate-subscription" },
    { "source": "/api/delete-account", "destination": "/api/delete-account" },
    { "source": "/api/send-renewal-reminders", "destination": "/api/send-renewal-reminders" },
    { "source": "/api/razorpay-webhook", "destination": "/api/razorpay-webhook" },
    { "source": "/api/reset-expired-subscriptions", "destination": "/api/reset-expired-subscriptions" },
    { "source": "/api/health", "destination": "/api/health" },
    { "source": "/api/log-error", "destination": "/api/log-error" },
    { "source": "/api/uptime-check", "destination": "/api/uptime-check" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "crons": [
    {
      "path": "/api/send-renewal-reminders",
      "schedule": "0 9 * * *"
    },
    {
      "path": "/api/reset-expired-subscriptions",
      "schedule": "0 0 * * *"
    },
    {
      "path": "/api/uptime-check",
      "schedule": "0 6 * * *"
    }
  ]
}
