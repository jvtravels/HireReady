{
  "buildCommand": "vite build",
  "outputDirectory": "dist",
  "framework": "vite",
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(self), geolocation=()" },
        { "key": "Strict-Transport-Security", "value": "max-age=63072000; includeSubDomains; preload" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/api/tts", "destination": "/api/tts" },
    { "source": "/api/generate-questions", "destination": "/api/generate-questions" },
    { "source": "/api/evaluate", "destination": "/api/evaluate" },
    { "source": "/api/analyze-resume", "destination": "/api/analyze-resume" },
    { "source": "/api/create-order", "destination": "/api/create-order" },
    { "source": "/api/verify-payment", "destination": "/api/verify-payment" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
